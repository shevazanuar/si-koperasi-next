# Contoh environment variables untuk SI Koperasi
# Salin file ini menjadi .env dan isi dengan nilai yang sesuai
# JANGAN commit file .env ke repository

# Database
DATABASE_URL="mysql://USER:PASSWORD@localhost:3306/kpripolinesdb"

# Next.js
NEXT_PUBLIC_APP_NAME="SI Koperasi KPRI Polines"

# SMTP (untuk fitur lupa password)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="email@example.com"
SMTP_PASS="your-app-password"
SMTP_FROM="SI Koperasi <email@example.com>"

# Session (gunakan string acak yang panjang)
SESSION_SECRET="ganti-dengan-string-acak-yang-panjang-min-32-karakter"
